{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@llm-observability/shared": ["packages/shared/dist/index.d.ts"],
      "@llm-observability/shared/*": ["packages/shared/dist/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
