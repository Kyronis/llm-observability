{
  "name": "llm-observability",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "pnpm -r run build",
    "build:web": "pnpm --filter @llm-observability/web build",
    "dev": "pnpm --filter @llm-observability/web dev",
    "lint": "pnpm -r run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "pnpm -r run clean"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.0"
  }
}
